
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>染上了拼豆 · 拼豆图纸生成器</title>
<style>
:root {
  --bg:#f4f1ec; --panel:#f7f4ef; --card:#fffdfa; --line:#e7e0d7; --text:#2f2924; --muted:#8e8478;
  --accent:#d88563; --dark:#231d19; --shadow:0 10px 28px rgba(84,63,39,.06); --radius:18px; --dot:rgba(207,196,184,.38);
}
* { box-sizing:border-box; }
html,body { margin:0; padding:0; height:100%; overflow:hidden; }
body { font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,"PingFang SC","Microsoft YaHei",sans-serif; background:var(--bg); color:var(--text); }
button,input,select { font:inherit; }
.hidden { display:none !important; }
.app {
  height:100vh; display:grid;
  grid-template-columns:320px 1fr 320px; grid-template-rows:60px 1fr;
  grid-template-areas:"top top top" "left main right";
}
.app.intro {
  grid-template-columns:1fr;
  grid-template-areas:"top" "main";
}
.app.intro .leftbar,
.app.intro .rightbar {
  display:none;
}
.app.intro .top-tools {
  visibility:hidden;
  pointer-events:none;
}
.topbar {
  grid-area:top; height:60px; display:grid; grid-template-columns:280px 1fr 320px; gap:16px; align-items:center;
  padding:0 20px; border-bottom:1px solid var(--line); background:rgba(248,245,240,.96); backdrop-filter:blur(10px);
}
.brand { display:flex; align-items:center; gap:12px; }
.logo { width:36px; height:36px; border-radius:12px; border:1px solid var(--line); background:#fff; display:grid; grid-template-columns:repeat(2,1fr); gap:4px; padding:6px; box-shadow:var(--shadow); }
.logo span { border-radius:999px; }
.brand strong { display:block; font-size:18px; line-height:1.1; font-weight:800; }
.brand span { display:block; font-size:12px; color:var(--muted); font-weight:700; margin-top:2px; }
.nav { display:flex; align-items:center; justify-content:center; gap:10px; }
.nav button, .small-btn, .icon-btn, .tool-chip, .main-btn {
  border:1px solid var(--line); border-radius:999px; background:#f1ede7; color:#6e645a; cursor:pointer;
}
.nav button { height:32px; padding:0 16px; font-size:13px; font-weight:800; color:#b1a69a; }
.nav button.active, .tool-chip.active { background:var(--dark); color:#fff; border-color:var(--dark); }
.top-tools { display:flex; justify-content:flex-end; align-items:center; gap:8px; }
.small-btn { height:34px; padding:0 12px; border-radius:10px; background:#faf7f3; font-size:13px; font-weight:800; }
.icon-btn { width:34px; height:34px; border-radius:10px; background:#faf7f3; font-weight:800; }
.main-btn { height:40px; padding:0 16px; border-radius:10px; background:var(--accent); color:#fff; border-color:var(--accent); font-weight:800; box-shadow:0 10px 20px rgba(216,133,99,.18); }
.leftbar,.rightbar { padding:14px; overflow:auto; background:var(--panel); overscroll-behavior:contain; }
.leftbar { grid-area:left; border-right:1px solid var(--line); }
.rightbar { grid-area:right; border-left:1px solid var(--line); }
.main {
  grid-area:main; min-width:0; overflow:hidden;
  background:radial-gradient(var(--dot) 1px, transparent 1px), var(--bg);
  background-size:20px 20px; background-position:10px 10px;
}
.main-scroll { height:100%; overflow:auto; padding:22px; overscroll-behavior:contain; }
.card { background:var(--card); border:1px solid var(--line); border-radius:22px; box-shadow:var(--shadow); padding:14px; }
.card + .card { margin-top:14px; }
.card h3 { margin:0 0 12px; font-size:14px; font-weight:800; }
.dropzone {
  min-height:148px; display:grid; place-items:center; text-align:center; padding:18px; border:1.5px dashed #d9cfc3; border-radius:18px;
  background:#faf7f3; color:var(--muted); cursor:pointer;
}
.dropzone.dragover { border-color:var(--accent); background:#fff3ee; }
.dropzone strong { display:block; margin-bottom:6px; color:#61584f; font-size:15px; }
.dropzone p { margin:0; font-size:13px; line-height:1.7; }
.upload-preview { max-width:100%; max-height:168px; display:block; border-radius:12px; box-shadow:var(--shadow); object-fit:contain; }
.grid2 { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
.stack { display:grid; gap:12px; }
.row { display:flex; align-items:center; justify-content:space-between; gap:10px; }
.label { font-size:13px; font-weight:800; color:#70675d; }
.value {
  min-width:48px; text-align:center; padding:5px 8px; border-radius:999px; background:#f2ece5;
  border:1px solid var(--line); color:#72695f; font-size:12px; font-weight:900;
}
input[type=range] { width:100%; accent-color:var(--accent); }
.field { width:100%; height:38px; border-radius:10px; border:1px solid var(--line); background:#fff; padding:0 12px; color:#5f554b; font-size:14px; }
.tool-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:8px; }
.tool-chip { height:38px; border-radius:10px; background:#f8f4ef; font-weight:800; }
.card-title-row { display:flex; align-items:center; justify-content:space-between; gap:10px; margin-bottom:12px; }
.card-title-row h3 { margin:0; }
.collapse-btn { height:32px; min-width:32px; padding:0 10px; border-radius:10px; border:1px solid var(--line); background:#faf7f3; color:#6e645a; font-size:12px; font-weight:900; cursor:pointer; transition:all .2s ease; }
.collapse-btn:hover { background:#f1ede7; }
.palette-card.is-collapsed .palette-content { display:none; }
.palette-card.is-collapsed .collapse-btn { background:var(--dark); color:#fff; border-color:var(--dark); }

.hero { min-height:calc(100vh - 104px); display:grid; place-items:center; padding:20px; }
.hero-inner { width:min(860px,100%); display:grid; grid-template-columns:270px 1fr; align-items:center; gap:34px; transform:translateY(-24px); }
.bead-art { width:270px; height:270px; display:grid; place-items:center; filter:drop-shadow(0 14px 18px rgba(143,116,88,.1)); }
.flower { display:grid; grid-template-columns:repeat(15,16px); grid-template-rows:repeat(15,16px); gap:3px; padding:16px; border-radius:32px; }
.bead { width:16px; height:16px; border-radius:999px; background:rgba(227,220,212,.72); box-shadow:inset 0 1px 0 rgba(255,255,255,.8); }
.hero-copy h2 { margin:0; font-size:34px; line-height:1.08; font-weight:800; }
.hero-copy p { margin:10px 0 0; color:var(--muted); font-size:14px; line-height:1.8; }
.hero-copy .slogan { margin-top:12px; color:var(--accent); font-size:18px; font-weight:800; }
.hero-actions { margin-top:18px; display:flex; gap:12px; flex-wrap:wrap; }
.hero-links { margin-top:14px; display:flex; gap:20px; color:#caa18f; font-size:14px; font-weight:800; }
.hero-links button { border:0; background:transparent; color:inherit; padding:0; cursor:pointer; }
.editor { display:none; min-height:calc(100vh - 104px); gap:14px; }
.editor.show { display:grid; grid-template-rows:auto auto 1fr; }
.summary { display:flex; flex-wrap:wrap; gap:10px; }
.pill { background:#fff8f3; height:32px; padding:0 12px; border-radius:999px; display:inline-flex; align-items:center; border:1px solid var(--line); font-size:12px; font-weight:900; color:#72695f; }
.metrics { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; }
.metric { border-radius:16px; border:1px solid var(--line); background:#faf7f3; padding:12px; }
.metric b { display:block; font-size:22px; line-height:1; margin-bottom:4px; }
.metric span { font-size:12px; color:var(--muted); font-weight:800; }
.main-board {
  background:var(--card); border:1px solid var(--line); border-radius:22px; box-shadow:var(--shadow); min-height:560px;
  display:grid; grid-template-columns:1fr; overflow:hidden;
}
.board-main { position:relative; min-width:0; display:grid; grid-template-rows:52px 1fr auto; }
.board-head {
  border-bottom:1px solid var(--line); padding:0 14px; display:flex; align-items:center; justify-content:space-between; gap:10px;
}
.board-head strong { font-size:14px; }
.board-head span { font-size:12px; color:var(--muted); font-weight:800; }
.board-canvas-wrap {
  min-height:0; overflow:auto; display:grid; place-items:start center; padding:18px;
  background:linear-gradient(45deg, rgba(242,238,232,.7) 25%, transparent 25%, transparent 75%, rgba(242,238,232,.7) 75%), linear-gradient(45deg, rgba(242,238,232,.7) 25%, transparent 25%, transparent 75%, rgba(242,238,232,.7) 75%);
  background-size:28px 28px; background-position:0 0,14px 14px;
}
.canvas-shell { background:#fff; border:1px solid var(--line); border-radius:16px; overflow:auto; position:relative; box-shadow:inset 0 1px 0 rgba(255,255,255,.8); }
.canvas-shell.empty::after { content:attr(data-empty); position:absolute; inset:0; display:grid; place-items:center; color:#b4a99d; font-size:13px; font-weight:800; pointer-events:none; }
.hover-chip { position:fixed; z-index:50; transform:translate(14px,14px); padding:7px 10px; border-radius:999px; border:1px solid var(--line); background:rgba(35,29,25,.92); color:#fff; font-size:12px; font-weight:900; line-height:1; pointer-events:none; box-shadow:0 10px 24px rgba(35,29,25,.18); white-space:nowrap; }
canvas { display:block; image-rendering:pixelated; }
.legend { display:flex; flex-wrap:wrap; gap:8px; padding:0 14px 14px; }
.legend-item { display:inline-flex; align-items:center; gap:8px; padding:8px 10px; border-radius:999px; border:1px solid var(--line); background:#faf7f3; font-size:12px; font-weight:800; color:#72695f; }
.sw { width:14px; height:14px; border-radius:4px; border:1px solid rgba(0,0,0,.06); }
.palette-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; }
.swatch { min-height:54px; border-radius:14px; border:2px solid transparent; cursor:pointer; box-shadow:inset 0 1px 0 rgba(255,255,255,.75); background:#faf7f3; padding:8px 10px; display:flex; align-items:center; gap:10px; text-align:left; }
.swatch.active { border-color:var(--dark); transform:scale(1.02); }
.swatch-dot { width:24px; height:24px; border-radius:8px; border:1px solid rgba(0,0,0,.08); flex:0 0 24px; }
.swatch-code { font-size:13px; font-weight:900; color:#5f554b; line-height:1.1; }
.list { display:grid; gap:8px; max-height:calc(100vh - 200px); overflow:auto; }
.color-row { display:grid; grid-template-columns:36px 1fr auto; gap:10px; align-items:center; padding:10px; border-radius:14px; border:1px solid var(--line); background:#faf7f3; }
.dot { width:36px; height:36px; border-radius:12px; border:1px solid rgba(0,0,0,.06); }
.color-meta strong { display:block; font-size:13px; line-height:1.2; }
.color-meta span { display:block; margin-top:3px; font-size:12px; color:var(--muted); }
.count { padding:6px 10px; border-radius:999px; border:1px solid var(--line); background:#f0e9e1; font-size:12px; font-weight:900; color:#6d645a; white-space:nowrap; }
.helper { color:var(--muted); font-size:12px; line-height:1.75; }
@media (max-width:1280px) {
  .app { grid-template-columns:320px 1fr; grid-template-areas:"top top" "left main"; }
  .rightbar { display:none; }
  .topbar { grid-template-columns:260px 1fr 220px; }
}
@media (max-width:980px) {
  .app { grid-template-columns:1fr; grid-template-areas:"top" "left" "main"; }
  .leftbar { border-right:0; border-bottom:1px solid var(--line); }
  .topbar { grid-template-columns:1fr; height:auto; padding:10px 14px; }
  .hero-inner,.main-board { grid-template-columns:1fr; }
  .metrics { grid-template-columns:repeat(2,1fr); }
}
</style>
</head>
<body>
<div class="app intro" id="appRoot">
  <header class="topbar">
    <div class="brand">
      <div class="logo"><span style="background:#f2a0b8"></span><span style="background:#8fb4ef"></span><span style="background:#f5d580"></span><span style="background:#8ed8b0"></span></div>
      <div><strong>染上了拼豆</strong><span>拼豆图纸生成器</span></div>
    </div>
    <div class="nav">
      <button class="active" id="navHome">首页</button>
      <button id="navEditor">开始制作</button>
    </div>
    <div class="top-tools">
      <button class="small-btn" id="downloadCsvBtn">下载 CSV</button>
      <button class="icon-btn" id="zoomOutBtn">－</button>
      <button class="icon-btn" id="zoomInBtn">＋</button>
    </div>
  </header>

  <aside class="leftbar">
    <div class="card">
      <h3>上传图片</h3>
      <div class="dropzone" id="dropZone">
        <img id="uploadPreview" class="upload-preview hidden" alt="上传原图预览" />
        <div id="uploadPlaceholder">
          <strong>拖拽图片到这里</strong>
          <p>支持 PNG / JPG / WEBP，也可以点击按钮选择本地图片。</p>
        </div>
      </div>
      <div class="grid2" style="margin-top:12px;">
        <button class="main-btn" id="pickBtn">选择图片</button>
        <button class="small-btn" id="resetBtn">清空</button>
      </div>
      <input id="fileInput" class="hidden" type="file" accept="image/*" />
    </div>

    <div class="card">
      <h3>生成参数</h3>
      <div class="stack">
        <div><div class="row"><span class="label">横向颗粒数</span><span class="value" id="gridWidthValue">48</span></div><input id="gridWidthRange" type="range" min="12" max="120" step="1" value="48" /></div>
        <div><div class="row"><span class="label">色号系统</span><span class="value" id="systemValue">MARD</span></div><select id="systemSelect" class="field"></select></div>
        <div><div class="row"><span class="label">预览像素大小</span><span class="value" id="cellSizeValue">8</span></div><input id="cellSizeRange" type="range" min="8" max="32" step="1" value="8" /></div>
        <div class="row"><span class="label">显示网格线</span><input id="showGridInput" type="checkbox" checked /></div>
        <div class="grid2">
          <button class="main-btn" id="generateBtn">生成图纸</button>
          <button class="small-btn" id="downloadBtn">下载 PNG</button>
        </div>
      </div>
    </div>

    <div class="card">
      <h3>编辑工具</h3>
      <div class="tool-grid" id="toolGroup">
        <button class="tool-chip active" data-tool="view">查看</button>
        <button class="tool-chip" data-tool="paint">上色</button>
        <button class="tool-chip" data-tool="replace">替换</button>
        <button class="tool-chip" data-tool="erase">连通擦除</button>
      </div>
      <div class="helper" style="margin-top:12px;">查看：点格子选色。上色：点击单格改色。替换：先点图中源颜色，再从下方色板选择目标色。连通擦除：点击一块颜色区域会做洪水填充擦除。</div>
    </div>

    <div class="card palette-card" id="paletteCard">
      <div class="card-title-row">
        <h3>完整调色板 · 291 色</h3>
        <button class="collapse-btn" id="paletteCollapseBtn" type="button" aria-expanded="true">收起</button>
      </div>
      <div class="palette-content" id="paletteContent">
        <div class="palette-grid" id="paletteGrid"></div>
        <div class="helper" style="margin-top:12px;">当前选中颜色：<span id="selectedColorText">无</span></div>
      </div>
    </div>
  </aside>

  <main class="main">
    <div class="main-scroll">
      <section class="hero" id="homeView">
        <div class="hero-inner">
          <div class="bead-art"><div class="flower" id="flower"></div></div>
          <div class="hero-copy">
            <h2>欢迎来到拼豆图纸生成器</h2>
            <p>重生之我是拼豆主理人</p>
            <div class="slogan">拼豆一时爽，一直拼一直爽</div>
            <div class="hero-actions">
              <button class="small-btn" id="heroPickBtn">上传图片</button>
            </div>
          </div>
        </div>
      </section>

      <section class="editor" id="editorView">
        <div class="summary">
          <div class="pill" id="statusGrid">未生成图纸</div>
          <div class="pill" id="statusColors">颜色 0 种</div>
          <div class="pill" id="statusBeads">总用豆 0</div>
        </div>

        <div class="metrics">
          <div class="metric"><b id="metricBeads">0</b><span>总用豆数</span></div>
          <div class="metric"><b id="metricColors">0</b><span>颜色种数</span></div>
          <div class="metric"><b id="metricGrid">-</b><span>网格尺寸</span></div>
        </div>

        <div class="main-board">

          <section class="board-main">
            <div class="board-head"><strong>拼豆图纸</strong><span id="patternInfo">可点击编辑</span></div>
            <div class="hover-chip hidden" id="hoverColorChip"></div>
            <div class="board-canvas-wrap">
              <div class="canvas-shell empty" id="patternWrap" data-empty="生成后显示拼豆图纸">
                <canvas id="patternCanvas" width="480" height="480"></canvas>
              </div>
            </div>
            
          </section>
        </div>
      </section>
    </div>
  </main>

  <aside class="rightbar">
    <div class="card">
      <h3>颜色统计</h3>
      <div class="list" id="statsList"></div>
    </div>
  </aside>
</div>

