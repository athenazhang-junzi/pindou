function floodFillErase(pixelData, gridDimensions, startRow, startCol, targetKey) { const {N,M} = gridDimensions; const newPixelData = pixelData.map(row => row.map(cell => ({...cell}))); const visited = Array(M).fill(null).map(() => Array(N).fill(false)); const stack = [{ row:startRow, col:startCol }]; while (stack.length > 0) { const {row,col} = stack.pop(); if (row<0 || row>=M || col<0 || col>=N || visited[row][col]) continue; const currentCell = newPixelData[row][col]; if (!currentCell || currentCell.isExternal || currentCell.key !== targetKey) continue; visited[row][col] = true; newPixelData[row][col] = { ...transparentColorData }; stack.push({row:row-1,col},{row:row+1,col},{row,col:col-1},{row,col:col+1}); } return newPixelData; }
