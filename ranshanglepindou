function paintSinglePixel(pixelData,row,col,newColor) { const newPixelData = pixelData.map(r => r.map(cell => ({...cell}))); const currentCell = newPixelData[row]?.[col]; if (!currentCell) return { newPixelData: pixelData, previousCell: null, hasChange: false }; const previousKey = currentCell.key, wasExternal = currentCell.isExternal; const newCellData = newColor.key === TRANSPARENT_KEY ? { ...transparentColorData } : { ...newColor, isExternal:false }; const hasChange = newCellData.key !== previousKey || newCellData.isExternal !== wasExternal; if (hasChange) newPixelData[row][col] = newCellData; return { newPixelData: hasChange ? newPixelData : pixelData, previousCell: currentCell, hasChange }; }
function recalculateColorStats(pixelData) { const colorCounts = {}; let totalCount = 0; pixelData.flat().forEach(cell => { if (cell && !cell.isExternal && cell.key !== TRANSPARENT_KEY) { const cellHex = cell.color.toUpperCase(); if (!colorCounts[cellHex]) colorCounts[cellHex] = { count:0, color:cellHex }; colorCounts[cellHex].count++; totalCount++; } }); return { colorCounts, totalCount }; }
function renderFlower() { const root = el('flower'); root.innerHTML = ''; const active = new Map([['7,7','#FBBF24'],['7,6','#FBBF24'],['7,8','#FBBF24'],['6,7','#FBBF24'],['8,7','#FBBF24'],['5,5','#F9A8D4'],['5,6','#F9A8D4'],['5,7','#F9A8D4'],['5,8','#F9A8D4'],['5,9','#F9A8D4'],['6,5','#F9A8D4'],['6,9','#F9A8D4'],['7,5','#F9A8D4'],['7,9','#F9A8D4'],['8,5','#F9A8D4'],['8,9','#F9A8D4'],['9,5','#F9A8D4'],['9,6','#F9A8D4'],['9,7','#F9A8D4'],['9,8','#F9A8D4'],['9,9','#F9A8D4'],['3,7','#93C5FD'],['4,7','#93C5FD'],['10,7','#93C5FD'],['11,7','#93C5FD'],['7,3','#93C5FD'],['7,4','#93C5FD'],['7,10','#93C5FD'],['7,11','#93C5FD'],['11,6','#86EFAC'],['12,6','#86EFAC'],['13,6','#86EFAC'],['11,8','#86EFAC'],['12,8','#86EFAC'],['13,8','#86EFAC']]); for (let r=0; r<15; r++) for (let c=0; c<15; c++) { const bead = document.createElement('span'); bead.className='bead'; const color = active.get(`${r},${c}`); if (color) bead.style.background = color; root.appendChild(bead); } }

function syncPaletteCollapseUI() { const card = el('paletteCard'); const btn = el('paletteCollapseBtn'); if (!card || !btn) return; card.classList.toggle('is-collapsed', state.paletteCollapsed); btn.textContent = state.paletteCollapsed ? '展开' : '收起'; btn.setAttribute('aria-expanded', String(!state.paletteCollapsed)); }
function togglePaletteCollapse() { state.paletteCollapsed = !state.paletteCollapsed; syncPaletteCollapseUI(); }
function renderPalette() { const html = BASE_PALETTE.map(item => { const key = item.code[state.currentSystem]; const active = state.selectedColor && state.selectedColor.color === item.hex; return `<button class="swatch ${active ? 'active' : ''}" data-hex="${item.hex}" data-key="${key}" title="${key} · ${item.hex}"><span class="swatch-dot" style="background:${item.hex}"></span><span class="swatch-code">${key}</span></button>`; }).join(''); el('paletteGrid').innerHTML = html; el('selectedColorText').textContent = state.selectedColor ? `${state.selectedColor.key} · ${state.selectedColor.color}` : '无'; el('paletteGrid').querySelectorAll('.swatch').forEach(btn => { btn.addEventListener('click', () => { const color = { key: btn.dataset.key, color: btn.dataset.hex, isExternal:false }; if (state.currentTool === 'replace' && state.selectedReplaceSource) { performColorReplace(state.selectedReplaceSource, color); state.selectedReplaceSource = null; } state.selectedColor = color; renderPalette(); }); }); }
function getLegendRows() { const rows = Object.entries(state.colorCounts).map(([hex,info]) => ({ color:hex, count:info.count, key:getDisplayColorKey(hex,state.currentSystem) })); return sortColorsByHue(rows); }
function updateUploadPreview() {
  const preview = el('uploadPreview');
  const placeholder = el('uploadPlaceholder');
  if (!state.image) {
    preview.classList.add('hidden');
    preview.removeAttribute('src');
    placeholder.classList.remove('hidden');
    return;
  }
  preview.src = state.image.src;
  preview.classList.remove('hidden');
  placeholder.classList.add('hidden');
}
function drawPattern() { const wrap = el('patternWrap'); if (!state.grid || !state.gridDimensions) { hideHoverColorChip(); wrap.classList.add('empty'); pctx.clearRect(0,0,patternCanvas.width,patternCanvas.height); el('patternInfo').textContent = '可点击编辑'; return; } wrap.classList.remove('empty'); const {N,M} = state.gridDimensions; patternCanvas.width = N * state.cellSize; patternCanvas.height = M * state.cellSize; pctx.clearRect(0,0,patternCanvas.width,patternCanvas.height); for (let row=0; row<M; row++) for (let col=0; col<N; col++) { const cell = state.grid[row][col], x = col * state.cellSize, y = row * state.cellSize; pctx.fillStyle = cell.isExternal ? '#FFFFFF' : cell.color; pctx.fillRect(x,y,state.cellSize,state.cellSize); if (state.showGrid) { pctx.strokeStyle = 'rgba(0,0,0,0.12)'; pctx.strokeRect(x+0.5,y+0.5,state.cellSize,state.cellSize); } if (!cell.isExternal && state.cellSize >= 16) { const rgb = hexToRgb(cell.color); const luminance = 0.299*rgb.r + 0.587*rgb.g + 0.114*rgb.b; pctx.fillStyle = luminance > 160 ? 'rgba(36,30,24,0.72)' : 'rgba(255,255,255,0.94)'; pctx.font = `700 ${Math.max(8, Math.floor(state.cellSize * 0.34))}px sans-serif`; pctx.textAlign = 'center'; pctx.textBaseline = 'middle'; pctx.fillText(getDisplayColorKey(cell.color,state.currentSystem), x + state.cellSize/2, y + state.cellSize/2); } } el('patternInfo').textContent = `${N} × ${M} · ${state.currentTool}`; }
function generatePattern() { if (!state.image) return; bufferCanvas.width = state.image.width; bufferCanvas.height = state.image.height; bctx.clearRect(0,0,bufferCanvas.width,bufferCanvas.height); bctx.drawImage(state.image, 0, 0); const N = state.gridWidth; const M = Math.max(1, Math.round((state.image.height / state.image.width) * N)); state.gridDimensions = { N, M }; const palette = BASE_PALETTE.map(item => ({ key:item.code[state.currentSystem], hex:item.hex, rgb:item.rgb })); state.grid = calculatePixelGrid(bctx, state.image.width, state.image.height, N, M, palette, palette[0]); const stats = recalculateColorStats(state.grid); state.colorCounts = stats.colorCounts; state.totalBeadCount = stats.totalCount; showEditor(); renderAll(); }
function buildStats() { const rows = getLegendRows(); el('metricBeads').textContent = state.totalBeadCount; el('metricColors').textContent = rows.length; el('metricGrid').textContent = state.gridDimensions ? `${state.gridDimensions.N}×${state.gridDimensions.M}` : '-'; el('statusGrid').textContent = state.gridDimensions ? `${state.gridDimensions.N} × ${state.gridDimensions.M}` : '未生成图纸'; el('statusColors').textContent = `颜色 ${rows.length} 种`; el('statusBeads').textContent = `总用豆 ${state.totalBeadCount}`; el('statsList').innerHTML = rows.length ? rows.map(item => `<div class="color-row"><div class="dot" style="background:${item.color}"></div><div class="color-meta"><strong>${item.key}</strong><span>${item.color}</span></div><div class="count">${item.count} 颗</div></div>`).join('') : `<div class="helper">生成图纸后这里会显示颜色统计。</div>`; }
function renderAll() { updateUploadPreview(); drawPattern(); renderPalette(); buildStats(); el('gridWidthValue').textContent = state.gridWidth; el('cellSizeValue').textContent = state.cellSize; el('systemValue').textContent = state.currentSystem; }
function getPatternCellAtEvent(evt) { if (!state.grid || !state.gridDimensions) return null; const rect = patternCanvas.getBoundingClientRect(); const scaleX = patternCanvas.width / rect.width, scaleY = patternCanvas.height / rect.height; const x = (evt.clientX - rect.left) * scaleX, y = (evt.clientY - rect.top) * scaleY; const col = Math.floor(x / state.cellSize), row = Math.floor(y / state.cellSize); if (row<0 || col<0 || row>=state.gridDimensions.M || col>=state.gridDimensions.N) return null; return { row, col }; }
function hideHoverColorChip() { const chip = el('hoverColorChip'); if (!chip) return; chip.classList.add('hidden'); chip.textContent = ''; }
function handlePatternHover(evt) { const chip = el('hoverColorChip'); const pos = getPatternCellAtEvent(evt); if (!chip || !pos || !state.grid) { hideHoverColorChip(); return; } const cell = state.grid[pos.row][pos.col]; if (!cell || cell.isExternal) { hideHoverColorChip(); return; } chip.textContent = getDisplayColorKey(cell.color, state.currentSystem); chip.style.left = `${evt.clientX}px`; chip.style.top = `${evt.clientY}px`; chip.classList.remove('hidden'); }
function performSinglePixelPaint(row,col,newColor) { if (!state.grid) return; const result = paintSinglePixel(state.grid,row,col,newColor); if (!result.hasChange) return; state.grid = result.newPixelData; const stats = recalculateColorStats(state.grid); state.colorCounts = stats.colorCounts; state.totalBeadCount = stats.totalCount; renderAll(); }
function performFloodFillErase(row,col,targetKey) { if (!state.grid || !state.gridDimensions) return; state.grid = floodFillErase(state.grid,state.gridDimensions,row,col,targetKey); const stats = recalculateColorStats(state.grid); state.colorCounts = stats.colorCounts; state.totalBeadCount = stats.totalCount; renderAll(); }
function performColorReplace(sourceColor,targetColor) { if (!state.grid || !state.gridDimensions) return; const result = replaceColor(state.grid,state.gridDimensions,sourceColor,targetColor); if (result.replaceCount <= 0) return; state.grid = result.newPixelData; const stats = recalculateColorStats(state.grid); state.colorCounts = stats.colorCounts; state.totalBeadCount = stats.totalCount; renderAll(); }
function handlePatternClick(evt) { const pos = getPatternCellAtEvent(evt); if (!pos || !state.grid) return; const cell = state.grid[pos.row][pos.col]; if (state.currentTool === 'paint') { if (state.selectedColor) performSinglePixelPaint(pos.row,pos.col,state.selectedColor); } else if (state.currentTool === 'erase') { if (!cell.isExternal) performFloodFillErase(pos.row,pos.col,cell.key); } else if (state.currentTool === 'replace') { if (!cell.isExternal) { state.selectedReplaceSource = { key:cell.key, color:cell.color }; state.selectedColor = { key:cell.key, color:cell.color, isExternal:false }; renderPalette(); el('selectedColorText').textContent = `待替换源色：${cell.key} · ${cell.color}`; } } else if (!cell.isExternal) { state.selectedColor = { key:getDisplayColorKey(cell.color,state.currentSystem), color:cell.color, isExternal:false }; renderPalette(); } }
function syncAppChrome() { el('appRoot').classList.toggle('intro', !state.image); }
function loadImage(file) { if (!file) return; const reader = new FileReader(); reader.onload = e => { const img = new Image(); img.onload = () => { state.image = img; syncAppChrome(); updateUploadPreview(); generatePattern(); }; img.src = e.target.result; }; reader.readAsDataURL(file); }
function showEditor() { if (!state.image) return; syncAppChrome(); el('homeView').style.display = 'none'; el('editorView').classList.add('show'); el('navHome').classList.remove('active'); el('navEditor').classList.add('active'); }
function showHome() { syncAppChrome(); el('homeView').style.display = 'grid'; el('editorView').classList.remove('show'); el('navHome').classList.add('active'); el('navEditor').classList.remove('active'); }
function setTool(tool) { state.currentTool = tool; el('toolGroup').querySelectorAll('.tool-chip').forEach(btn => btn.classList.toggle('active', btn.dataset.tool === tool)); }
function resetState() { state.image = null; state.grid = null; state.gridDimensions = null; state.colorCounts = {}; state.totalBeadCount = 0; state.selectedReplaceSource = null; hideHoverColorChip(); syncAppChrome(); updateUploadPreview(); drawPattern(); buildStats(); showHome(); }
function downloadPatternPng() { if (!state.grid) return; const link = document.createElement('a'); link.href = patternCanvas.toDataURL('image/png'); link.download = 'perler-pattern.png'; link.click(); }
function downloadCsv() { const rows = getLegendRows(); if (!rows.length) return; const csv = [['key','hex','count'], ...rows.map(item => [item.key,item.color,item.count])].map(r => r.join(',')).join('\n'); const blob = new Blob([csv], { type:'text/csv;charset=utf-8' }); const url = URL.createObjectURL(blob); const link = document.createElement('a'); link.href = url; link.download = 'perler-stats.csv'; link.click(); URL.revokeObjectURL(url); }
function bindEvents() {
  el('systemSelect').innerHTML = COLOR_SYSTEMS.map(sys => `<option value="${sys}">${sys}</option>`).join('');
  el('systemSelect').value = state.currentSystem;
  syncPaletteCollapseUI();

  const on = (id, event, handler) => {
    const node = el(id);
    if (node) node.addEventListener(event, handler);
  };

  on('paletteCollapseBtn', 'click', togglePaletteCollapse);
  on('pickBtn', 'click', () => el('fileInput').click());
  on('heroPickBtn', 'click', () => el('fileInput').click());
  on('fileInput', 'change', e => loadImage(e.target.files[0]));
  on('resetBtn', 'click', resetState);
  on('generateBtn', 'click', generatePattern);
  on('downloadBtn', 'click', downloadPatternPng);
  on('downloadCsvBtn', 'click', downloadCsv);
  on('zoomInBtn', 'click', () => { state.cellSize = Math.min(40, state.cellSize + 2); el('cellSizeRange').value = state.cellSize; renderAll(); });
  on('zoomOutBtn', 'click', () => { state.cellSize = Math.max(6, state.cellSize - 2); el('cellSizeRange').value = state.cellSize; renderAll(); });
  on('gridWidthRange', 'input', e => { state.gridWidth = Number(e.target.value); renderAll(); });
  on('cellSizeRange', 'input', e => { state.cellSize = Number(e.target.value); renderAll(); });
  on('systemSelect', 'change', e => { state.currentSystem = e.target.value; if (state.selectedColor) state.selectedColor.key = getDisplayColorKey(state.selectedColor.color, state.currentSystem); renderAll(); });
  on('showGridInput', 'change', e => { state.showGrid = e.target.checked; renderAll(); });
  on('navHome', 'click', showHome);
  on('navEditor', 'click', showEditor);

  el('toolGroup').querySelectorAll('.tool-chip').forEach(btn => btn.addEventListener('click', () => setTool(btn.dataset.tool)));
  patternCanvas.addEventListener('click', handlePatternClick);
  patternCanvas.addEventListener('mousemove', handlePatternHover);
  patternCanvas.addEventListener('mouseleave', hideHoverColorChip);

  const dropZone = el('dropZone');
  ['dragenter', 'dragover'].forEach(type => dropZone.addEventListener(type, e => { e.preventDefault(); dropZone.classList.add('dragover'); }));
  ['dragleave', 'drop'].forEach(type => dropZone.addEventListener(type, e => { e.preventDefault(); dropZone.classList.remove('dragover'); }));
  dropZone.addEventListener('drop', e => loadImage(e.dataTransfer.files[0]));
  dropZone.addEventListener('click', () => el('fileInput').click());
}
renderFlower(); bindEvents(); syncAppChrome(); renderPalette(); buildStats(); updateUploadPreview(); drawPattern();
</script>
</body>
